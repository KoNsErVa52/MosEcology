<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>МосЭкология</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        body {
            background-color: rgb(217, 253, 217);
            color: #333;
            line-height: 1.6;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }
        header {
            background: linear-gradient(135deg, #25ac2c 0%, #25ac2c 100%);
            color: white;
            padding: 20px 0;
            box-shadow: 0 4px 12px rgba(255, 8, 8, 0.1);
            position: sticky;
            top: 0;
            z-index: 100;
        }
        .spacer {
            height: 50px;
        }
        .park-description {
            font-size: 17px;
        }
        .header-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .logo {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        .logo i {
            font-size: 2.5rem;
        }
        .logo h1 {
            font-size: 1.8rem;
            font-weight: 700;
        }
        nav ul {
            display: flex;
            list-style: none;
            gap: 30px;
            align-items: center;
        }
        nav a {
            color: white;
            text-decoration: none;
            font-weight: 600;
            padding: 8px 15px;
            border-radius: 5px;
            transition: all 0.3s ease;
            position: relative;
        }
        nav a:hover, .nav-active {
            background-color: rgba(255, 0, 0, 0);
        }
        .dropdown {
            position: relative;
        }
        .dropdown-content {
            display: none;
            position: absolute;
            background-color: rgb(19, 131, 19);
            min-width: 200px;
            box-shadow: 0px 8px 16px 0px rgba(255, 0, 0, 0.2);
            z-index: 101;
            border-radius: 5px;
            top: 100%;
            left: 0;
            overflow: hidden;
        }
        .dropdown-content a {
            color: #333;
            padding: 12px 16px;
            text-decoration: none;
            display: block;
            text-align: left;
            transition: background-color 0.3s;
        }
        .dropdown-content a:hover {
            background-color: #296d2e;
            color: #ffffff;
        }
        .dropdown:hover .dropdown-content {
            display: block;
        }
        .hero {
            background:url("т");
            background-size: cover;
            background-position: center;
            color: rgb(0, 0, 0);
            text-align: center;
            padding: 100px 0;
            margin-bottom: 50px;
        }
        .hero h1 {
            font-size: 3.5rem;
            margin-bottom: 20px;
            text-shadow: 2px 2px 4px rgb(255, 255, 255);
        }
        .hero p {
            font-size: 1.3rem;
            max-width: 800px;
            margin: 0 auto 30px;
        }
        .btn {
            display: inline-block;
            background-color: #2e7d32;
            color: white;
            padding: 12px 30px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            border: none;
            cursor: pointer;
        }
        .btn:hover {
            background-color: #1b5e20;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255, 0, 0, 0.2);
        }
        .section {
            padding: 60px 0;
            border-bottom: 1px solid #e0e0e0;
        }
        .section-title {
            text-align: center;
            margin-bottom: 40px;
            color: #1b5e20;
            font-size: 2.5rem;
        }
        .content-card {
            background-color: white;
            border-radius: 10px;
            padding: 30px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.473);
            margin-bottom: 30px;
            transition: transform 0.3s ease;
        }
        .content-card:hover {
            transform: translateY(-5px);
        }
        .content-card h2 {
            color: #2e7d32;
            margin-bottom: 15px;
            font-size: 1.8rem;
        }
        .content-card h3 {
            color: #388e3c;
            margin: 20px 0 10px;
            font-size: 1.4rem;
        }
        .content-card ul {
            padding-left: 20px;
            margin: 15px 0;
        }
        .content-card li {
            margin-bottom: 8px;
        }
        .content-card img {
            width: 100%;
            border-radius: 10px;
            margin: 20px 0;
            box-shadow: 0 4px 8px rgba(255, 0, 0, 0.1);
        }
        .image-gallery {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
            margin-top: 40px;
        }
        .gallery-item {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(255, 0, 0, 0.1);
            transition: transform 0.3s ease;
        }
        .gallery-item:hover {
            transform: scale(1.03);
        }
        .gallery-item img {
            width: 100%;
            height: 250px;
            object-fit: cover;
            display: block;
        }
        .tabs {
            display: flex;
            margin-bottom: 30px;
            border-bottom: 2px solid #e0e0e0;
        }
        .tab-btn {
            background: none;
            border: none;
            padding: 15px 30px;
            font-size: 1.1rem;
            font-weight: 600;
            color: #666;
            cursor: pointer;
            transition: all 0.3s ease;
            border-bottom: 3px solid transparent;
        }
        .tab-btn:hover {
            color: #2e7d32;
        }
        .tab-btn.active {
            color: #2e7d32;
            border-bottom: 3px solid #2e7d32;
        }
        .tab-content {
            display: none;
            animation: fadeIn 0.5s ease;
        }
        .tab-content.active {
            display: block;
        }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }
        .problem-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 30px;
        }
        .problem-card {
            background-color: white;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
        }
        .problem-card:hover {
            box-shadow: 0 10px 25px rgba(255, 255, 255, 0.1);
        }
        .problem-header {
            background-color: #2e7d32;
            color: white;
            padding: 20px;
            text-align: center;
        }
        .problem-body {
            padding: 25px;
        }
        .problem-body h3 {
            color: #2e7d32;
            margin-bottom: 15px;
        }
        .problem-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 25px;
            justify-content: center;
        }
        .problem-btn {
            background-color: #2e7d32;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            text-align: center;
        }
        .problem-btn:hover {
            background-color: #1b5e20;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(255, 255, 255, 0.2);
        }
        .problem-btn.blue {
            background-color: #2196f3;
        }
        .problem-btn.blue:hover {
            background-color: #0d8bf2;
        }
        .problem-btn.orange {
            background-color: #ff9800;
        }
        .problem-btn.orange:hover {
            background-color: #e68900;
        }
        .problem-btn.red {
            background-color: #f44336;
        }
        .problem-btn.red:hover {
            background-color: #e53935;
        }
        footer {
            background-color: #1b5e20;
            color: white;
            padding: 50px 0 20px;
            margin-top: 50px;
        }
        .footer-content {
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            margin-bottom: 40px;
        }
        .footer-column {
            flex: 1;
            min-width: 250px;
            margin-bottom: 30px;
        }
        .footer-column h3 {
            font-size: 1.5rem;
            margin-bottom: 20px;
            color: #a5d6a7;
        }
        .footer-column ul {
            list-style: none;
        }
        .footer-column li {
            margin-bottom: 10px;
        }
        .footer-column a {
            color: #e8f5e9;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        .footer-column a:hover {
            color: rgb(0, 0, 0);
        }
        .copyright {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid rgba(255, 0, 0, 0.1);
            color: #a5d6a7;
            font-size: 0.9rem;
        }
        .page {
            display: none;
        }
        .page.active {
            display: block;
        }
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 25px;
            margin-top: 40px;
        }
        .stat-card {
            background-color: white;
            border-radius: 10px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 5px 15px rgba(255, 252, 252, 0.05);
        }
        .stat-card i {
            font-size: 3rem;
            color: #2e7d32;
            margin-bottom: 15px;
        }
        .stat-card h3 {
            font-size: 2rem;
            color: #1b5e20;
            margin-bottom: 10px;
        }
        .initiative-card {
            background-color: white;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(255, 0, 0, 0.05);
            display: flex;
            gap: 25px;
            align-items: center;
        }
        .initiative-icon {
            flex-shrink: 0;
            width: 80px;
            height: 80px;
            background-color: #e8f5e9;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .initiative-icon i {
            font-size: 2.5rem;
            color: #2e7d32;
        }
        .initiative-content {
            flex-grow: 1;
        }
        .initiative-content h3 {
            color: #2e7d32;
            margin-bottom: 10px;
        }
        .rating-numbers {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 20px;
            justify-content: center;
            padding: 20px 0;
        }
        .rating-number {
            display: inline-block;
            background-color: #2e7d32;
            color: white;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            text-align: center;
            line-height: 50px;
            font-weight: bold;
            font-size: 1.4rem;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.15);
            position: relative;
        }
        .rating-number:hover {
            transform: scale(1.15);
            box-shadow: 0 6px 12px rgba(0, 0, 0, 0.25);
        }
        .rating-number.negative {
            background-color: #c62828;
        }
        .rating-number::after {
            content: 'ℹ️';
            position: absolute;
            top: -8px;
            right: -8px;
            font-size: 0.9rem;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .rating-number:hover::after {
            opacity: 1;
        }
        .district-map {
            width: 100%;
            border-radius: 10px;
            margin: 15px 0;
            border: 3px solid #2e7d32;
        }
        .district-map.negative {
            border-color: #c62828;
        }
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 2000;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .modal-overlay.active {
            display: flex;
            animation: fadeIn 0.3s ease;
        }
        .modal-content {
            background-color: white;
            border-radius: 15px;
            max-width: 800px;
            width: 100%;
            max-height: 90vh;
            overflow-y: auto;
            box-shadow: 0 15px 40px rgba(255, 12, 12, 0.4);
            position: relative;
            animation: modalSlideIn 0.4s ease;
        }
        @keyframes modalSlideIn {
            from { opacity: 0; transform: translateY(-50px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .modal-header {
            background: linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%);
            color: white;
            padding: 25px;
            border-radius: 15px 15px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .modal-header.negative {
            background: linear-gradient(135deg, #c62828 0%, #b71c1c 100%);
        }
        .modal-header h3 {
            margin: 0;
            font-size: 1.8rem;
        }
        .close-modal {
            background: none;
            border: none;
            color: white;
            font-size: 2rem;
            cursor: pointer;
            padding: 5px 10px;
            line-height: 1;
            border-radius: 50%;
            transition: background-color 0.3s;
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .close-modal:hover {
            background-color: rgba(255, 255, 255, 0.2);
        }
        .modal-body {
            padding: 30px;
        }
        .modal-body p {
            margin-bottom: 20px;
            line-height: 1.7;
            font-size: 1.1rem;
        }
        .modal-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 15px;
            margin: 25px 0;
            background-color: #f9f9f9;
            padding: 20px;
            border-radius: 10px;
        }
        .stat-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #e0e0e0;
        }
        .stat-item:last-child {
            border-bottom: none;
        }
        .stat-label {
            font-weight: 600;
            color: #555;
        }
        .stat-value {
            font-weight: 700;
            color: #2e7d32;
        }
        .stat-value.negative {
            color: #c62828;
        }
        .district-image-container {
            text-align: center;
            margin: 20px 0;
        }
        .rating-intro {
            background-color: #e8f5e9;
            padding: 30px;
            border-radius: 10px;
            margin: 30px 0;
            text-align: center;
        }
        .year-badge {
            display: inline-block;
            background-color: #ff9800;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            margin-bottom: 15px;
        }
        .rating-comparison {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 30px;
            margin-top: 30px;
        }
        .quiz-container {
            max-width: 800px;
            margin: 0 auto;
        }
        .quiz-card {
            background-color: white;
            border-radius: 10px;
            padding: 30px;
            margin-bottom: 30px;
            box-shadow: 0 5px 15px rgba(255, 0, 0, 0.1);
        }
        .quiz-question {
            font-size: 1.3rem;
            margin-bottom: 25px;
            color: #1b5e20;
            font-weight: 600;
        }
        .quiz-options {
            display: flex;
            flex-direction: column;
            gap: 15px;
            margin-bottom: 30px;
        }
        .quiz-option {
            background-color: #f5f5f5;
            border: 2px solid #ddd;
            border-radius: 8px;
            padding: 15px 20px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.1rem;
            display: flex;
            align-items: center;
        }
        .quiz-option:hover {
            background-color: #e8f5e9;
            border-color: #2e7d32;
        }
        .quiz-option.selected {
            background-color: #c8e6c9;
            border-color: #2e7d32;
        }
        .quiz-option.correct {
            background-color: #c8e6c9;
            border-color: #2e7d32;
        }
        .quiz-option.incorrect {
            background-color: #ffcdd2;
            border-color: #c62828;
        }
        .quiz-option.disabled {
            cursor: not-allowed;
            opacity: 0.7;
        }
        .quiz-option-label {
            display: inline-block;
            width: 30px;
            height: 30px;
            line-height: 30px;
            text-align: center;
            background-color: #2e7d32;
            color: white;
            border-radius: 50%;
            margin-right: 15px;
            font-weight: bold;
        }
        .quiz-option-label.incorrect {
            background-color: #c62828;
        }
        .quiz-button {
            background-color: #2e7d32;
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 5px;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 10px;
        }
        .quiz-button:hover {
            background-color: #1b5e20;
            transform: translateY(-2px);
        }
        .quiz-button:disabled {
            background-color: #cccccc;
            cursor: not-allowed;
            transform: none;
        }
        .quiz-results {
            text-align: center;
            padding: 30px;
            background-color: #e8f5e9;
            border-radius: 10px;
            margin-top: 30px;
        }
        .quiz-score {
            font-size: 2.5rem;
            color: #2e7d32;
            font-weight: bold;
            margin: 20px 0;
        }
        .quiz-feedback {
            font-size: 1.2rem;
            margin-bottom: 20px;
        }
        .quiz-explanation {
            background-color: white;
            padding: 20px;
            border-radius: 8px;
            margin-top: 20px;
            text-align: left;
        }
        .quiz-progress {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            background-color: #e8f5e9;
            padding: 15px;
            border-radius: 8px;
        }
        .question-counter {
            font-size: 1.2rem;
            font-weight: bold;
            color: #1b5e20;
            background-color: white;
            padding: 8px 15px;
            border-radius: 20px;
            box-shadow: 0 2px 5px rgba(255, 255, 255, 0.1);
        }
        .quiz-progress-bar {
            flex-grow: 1;
            height: 8px;
            background-color: #e0e0e0;
            border-radius: 4px;
            margin: 0 20px;
            overflow: hidden;
        }
        .quiz-progress-fill {
            height: 100%;
            background-color: #2e7d32;
            width: 0%;
            transition: width 0.5s ease;
        }
        .terms-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }
        .term-card {
            background-color: white;
            border-radius: 10px;
            padding: 25px;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            transition: all 0.3s ease;
            border-left: 5px solid #2e7d32;
            cursor: pointer;
        }
        .term-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
        }
        .term-card h3 {
            color: #2e7d32;
            margin-bottom: 10px;
            font-size: 1.3rem;
        }
        .term-card p {
            color: #555;
            line-height: 1.6;
        }
        .term-icon {
            font-size: 2rem;
            color: #2e7d32;
            margin-bottom: 15px;
        }
        .term-category {
            display: inline-block;
            background-color: #e8f5e9;
            color: #2e7d32;
            padding: 5px 10px;
            border-radius: 15px;
            font-size: 0.8rem;
            font-weight: 600;
            margin-top: 10px;
        }
        .term-modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.8);
            z-index: 2001;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .term-modal-overlay.active {
            display: flex;
            animation: fadeIn 0.3s ease;
        }
        .term-modal-content {
            background-color: white;
            border-radius: 15px;
            max-width: 600px;
            width: 100%;
            max-height: 80vh;
            overflow-y: auto;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.4);
            position: relative;
            animation: modalSlideIn 0.4s ease;
        }
        .term-modal-header {
            background: linear-gradient(135deg, #2e7d32 0%, #1b5e20 100%);
            color: white;
            padding: 25px;
            border-radius: 15px 15px 0 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .term-modal-header h3 {
            margin: 0;
            font-size: 1.8rem;
        }
        .term-modal-body {
            padding: 30px;
        }
        .term-modal-body p {
            margin-bottom: 20px;
            line-height: 1.7;
            font-size: 1.1rem;
        }
        .term-modal-example {
            background-color: #e8f5e9;
            padding: 15px;
            border-radius: 8px;
            margin: 20px 0;
            border-left: 4px solid #2e7d32;
        }
        .term-modal-example h4 {
            color: #2e7d32;
            margin-bottom: 10px;
        }
        .quiz-selector {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-bottom: 40px;
            flex-wrap: wrap;
        }
        .quiz-selector-btn {
            background-color: #e8f5e9;
            border: 2px solid #2e7d32;
            padding: 15px 30px;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            color: #2e7d32;
            min-width: 200px;
        }
        .quiz-selector-btn:hover {
            background-color: #c8e6c9;
            transform: translateY(-3px);
        }
        .quiz-selector-btn.active {
            background-color: #2e7d32;
            color: white;
        }
        .tips-section {
            margin-top: 60px;
            padding-top: 40px;
            border-top: 2px solid #e0e0e0;
        }
